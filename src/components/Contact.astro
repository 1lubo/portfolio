---
// Contact section & footer
---

<section id="contact" class="py-24 lg:py-32">
  <div class="section-container">
    <div class="max-w-2xl mx-auto text-center">
      <!-- Section header -->
      <p class="font-mono text-sm text-accent-bitcoin mb-3">// get in touch</p>
      <h2 class="font-heading text-3xl lg:text-4xl font-bold text-content-strong mb-6">Let's Build Something</h2>
      <p class="text-content-muted text-lg mb-10 leading-relaxed">
        Interested in collaborating on Bitcoin, Lightning, or Nostr projects?
        I'm always open to discussing new ideas and opportunities.
      </p>

      <!-- Contact links -->
      <div class="flex flex-wrap justify-center gap-4 mb-16">
        <a
          href="https://github.com/1lubo"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-800 border border-line/50 rounded-lg
                 text-content hover:text-content-strong hover:border-content-subtle transition-all text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
          GitHub
        </a>

        <a
          href="mailto:1Lubo@pm.me"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-800 border border-line/50 rounded-lg
                 text-content hover:text-content-strong hover:border-content-subtle transition-all text-sm"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          Email
        </a>

        <a
          href="https://njump.me/npub1v0c4w6j477dxelfv9vv5zgfq7nxp586ght89nwjv4rsxwh2j72aqt2fs2r"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-800 border border-accent-nostr/30 rounded-lg
                 text-accent-nostr hover:bg-accent-nostr/10 transition-all text-sm"
        >
          <span class="text-lg">🟣</span>
          Nostr
        </a>

        <a
          href="lightning:quietpimple356@walletofsatoshi.com"
          class="inline-flex items-center gap-2 px-5 py-3 bg-surface-800 border border-accent-bitcoin/30 rounded-lg
                 text-accent-bitcoin hover:bg-accent-bitcoin/10 transition-all text-sm"
        >
          <span class="text-lg">⚡</span>
          Tip via Lightning
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="border-t border-line/50 py-8">
  <div class="section-container flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-content-subtle text-sm font-mono">
      <span class="text-accent-bitcoin">&gt;</span> built with Astro + Tailwind
    </p>
    <p class="text-content-subtle text-xs">
      &copy; {new Date().getFullYear()} — All rights reserved
    </p>
  </div>
</footer>
