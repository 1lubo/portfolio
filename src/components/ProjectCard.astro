---
interface Props {
  title: string;
  subtitle: string;
  description: string;
  tags: string[];
  highlights: string[];
  accentColor: 'bitcoin' | 'nostr' | 'python';
  liveUrl?: string;
  githubUrl?: string;
  docsUrl?: string;
}

const { title, subtitle, description, tags, highlights, accentColor, liveUrl, githubUrl, docsUrl } = Astro.props;

const accentClasses = {
  bitcoin: 'border-accent-bitcoin/30 text-accent-bitcoin',
  nostr: 'border-accent-nostr/30 text-accent-nostr',
  python: 'border-accent-python/30 text-accent-python',
};

const glowClasses = {
  bitcoin: 'hover:shadow-[0_0_30px_rgba(247,147,26,0.1)] hover:border-accent-bitcoin/40',
  nostr: 'hover:shadow-[0_0_30px_rgba(139,92,246,0.1)] hover:border-accent-nostr/40',
  python: 'hover:shadow-[0_0_30px_rgba(59,130,246,0.1)] hover:border-accent-python/40',
};
---

<article class={`bg-surface-800 border border-line/60 rounded-xl p-6 lg:p-8 transition-all duration-300 ease-out hover:scale-[1.01] ${glowClasses[accentColor]}`}>
  <!-- Header -->
  <div class="flex items-start justify-between mb-4">
    <div>
      <div class="flex flex-wrap items-center gap-3 mb-1">
        <h3 class="font-heading text-xl lg:text-2xl font-bold text-content-strong">{title}</h3>
        <span class="text-[10px] font-mono px-2 py-0.5 rounded-full bg-surface-700 text-content-subtle border border-line/50">Personal Project</span>
      </div>
      <p class="font-mono text-sm text-content-subtle">{subtitle}</p>
    </div>
    <div class="flex gap-2">
      {liveUrl && (
        <a href={liveUrl} target="_blank" rel="noopener" class="text-content-subtle hover:text-content-strong transition-colors" title="Live Demo">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      )}
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener" class="text-content-subtle hover:text-content-strong transition-colors" title="Source Code">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
          </svg>
        </a>
      )}
    </div>
  </div>

  <!-- Description -->
  <p class="text-content-muted text-sm leading-relaxed mb-5">{description}</p>

  <!-- Highlights -->
  <ul class="space-y-2 mb-6">
    {highlights.map((h) => (
      <li class="flex items-start gap-2 text-sm text-content">
        <span class={`mt-1 w-1.5 h-1.5 rounded-full flex-shrink-0 ${accentColor === 'bitcoin' ? 'bg-accent-bitcoin' : accentColor === 'nostr' ? 'bg-accent-nostr' : 'bg-accent-python'}`}></span>
        {h}
      </li>
    ))}
  </ul>

  <!-- Tags -->
  <div class="flex flex-wrap gap-2">
    {tags.map((tag) => (
      <span class={`tech-pill ${accentClasses[accentColor]}`}>{tag}</span>
    ))}
  </div>
</article>
